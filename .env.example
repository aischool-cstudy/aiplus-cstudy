# ==============================
# Web (필수)
# ==============================
# 웹 서버가 FastAPI를 호출할 기본 주소 (Docker 환경에서는 docker-compose가 덮어씀)
FASTAPI_URL=http://localhost:8000
# FastAPI 호출 재시도 정책 (최종 실패는 그대로 반환)
FASTAPI_MAX_RETRIES=0
FASTAPI_RETRY_BASE_MS=250

# ==============================
# AI 연동 (필수)
# ==============================
# 기본 공급자: gemini | openai
AI_PROVIDER=gemini

# ==============================
# Gemini (AI_PROVIDER=gemini 일 때 필수)
# ==============================
# GEMINI_API_KEY 우선, 없으면 GOOGLE_GENERATIVE_AI_API_KEY도 인식
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ==============================
# OpenAI 호환 API (AI_PROVIDER=openai 일 때 필수)
# ==============================
# OpenAI / Groq / OpenRouter 등 chat/completions 호환 엔드포인트 사용 가능
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ==============================
# API 런타임
# ==============================
ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# AI API 요청 타임아웃 (초)
AI_REQUEST_TIMEOUT_SEC=60
# FastAPI 내부 AI 동시성 제한 / 백프레셔 타임아웃 (ms)
AI_MAX_CONCURRENCY=4
AI_BACKPRESSURE_ACQUIRE_TIMEOUT_MS=200
# 진단 "분석하기" 속도 모드: rule | llm
ASSESSMENT_ANALYSIS_MODE=rule

# ==============================
# JWT
# ==============================
JWT_SECRET=change-me-in-production

# ==============================
# 선택 설정
# ==============================
# FastAPI에서 직접 DB를 사용할 때 (기본 플로우에서는 docker-compose가 주입)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/aiplus